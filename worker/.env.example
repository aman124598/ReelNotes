SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
GROQ_API_KEY=gsk_your_groq_key
WORKER_SECRET=choose_a_shared_secret
# Optional: path to exported Instagram cookies.txt for better yt-dlp success
YTDLP_COOKIES_FILE=
MAX_RETRIES=3
MAX_DURATION_SECONDS=180
WHISPER_MODEL_SIZE=large-v3-turbo
WHISPER_FALLBACK_MODEL_SIZE=tiny
GROQ_MODEL=llama-3.3-70b-versatile
OCR_ENABLED=true
OCR_FRAME_INTERVAL_SECONDS=1.5
OCR_MAX_FRAMES=8
OCR_LANG=eng
OCR_MIN_LINE_LENGTH=3
FORCE_AUDIO_TRANSCRIBE=false
# Optional: full path to tesseract binary if not in PATH.
# Example on Windows: C:\\Program Files\\Tesseract-OCR\\tesseract.exe
TESSERACT_CMD=
# Auto-poll queued jobs while worker is running (recommended for local/dev).
AUTO_POLL_ENABLED=true
AUTO_POLL_INTERVAL_SECONDS=5
AUTO_POLL_ERROR_BACKOFF_SECONDS=8
